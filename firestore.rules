rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSurvey(data) {
      return data.keys().hasAll(['createdAt', 'userId'])
          && data.userId is string
          && data.createdAt is number;
    }

    match /surveys/{surveyId} {
      allow read: if true;
      allow create: if isValidId(surveyId)
                    && isValidSurvey(incoming())
                    && incoming().keys().size() <= 150;
      allow update: if isValidSurvey(incoming())
                    && incoming().userId == existing().userId;
      allow delete: if true;
    }
  }
}
