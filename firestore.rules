rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSurvey(data) {
      return data.keys().hasAll(['createdAt', 'userId'])
          && data.userId == request.auth.uid
          && data.createdAt is number;
    }

    match /surveys/{surveyId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() 
                    && isValidId(surveyId)
                    && isValidSurvey(incoming())
                    && incoming().createdAt == request.time.toMillis()
                    && incoming().keys().size() <= 60; // Just an upper bound
      allow update: if isSignedIn() && existing().userId == request.auth.uid
                    && isValidSurvey(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
